# Database
POSTGRES_DB=tachiya
POSTGRES_USER=tachiya
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://tachiya:changeme@db:5432/tachiya

# Cache / Celery (valkey/redis)
CACHE_URL=redis://cache:6379/0
CELERY_BROKER_URL=redis://cache:6379/1
CELERY_RESULT_BACKEND=redis://cache:6379/2

# Saleor
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,saleor
DEFAULT_CHANNEL_SLUG=default-channel
DASHBOARD_URL=http://localhost:9000/
HTTP_IP_FILTER_ALLOW_LOOPBACK_IPS=True
HTTP_IP_FILTER_ENABLED=True

# Superuser (dev only) - 用於 `manage.py createsuperuser --noinput`
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin

# Email (dev 用 mailpit，prod 換成真實 SMTP)
EMAIL_URL=smtp://mailpit:1025
DEFAULT_FROM_EMAIL=noreply@example.com

# Storefront
NEXT_PUBLIC_SALEOR_API_URL=http://localhost:8000/graphql/
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_CHANNEL=default-channel

# Tachiya FastAPI
SALEOR_GRAPHQL_URL=http://saleor:8000/graphql/
